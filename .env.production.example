# ── Production Environment Variables ─────────────────────────────────────────
# Copy this file to .env in the project root before running docker compose.
#
# NEVER commit .env to git. It is already in .gitignore.
#
# Generate JWT secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Run it TWICE to get two different secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_20_CHARS

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=500

# ── CORS & URLs ───────────────────────────────────────────────────────────────
# Set to your actual frontend domain — no trailing slash
CORS_ORIGIN=https://yourdomain.com
CLIENT_URL=https://yourdomain.com
# Set to your API domain — used at React build time (baked into the JS bundle)
VITE_API_URL=https://yourdomain.com/api/v1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Email ─────────────────────────────────────────────────────────────────────
# Required — password reset emails will silently fail if EMAIL_FROM is not set
# to a real address and EMAIL_USER / EMAIL_PASSWORD are not filled in.
EMAIL_FROM=noreply@yourdomain.com
EMAIL_SERVICE=gmail
EMAIL_USER=your-gmail-address@gmail.com
# For Gmail use an App Password (not your account password):
#   Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASSWORD=REPLACE_WITH_APP_PASSWORD

# ── TLS certificates (used by docker-compose.prod.yml) ───────────────────────
# Paths on the HOST machine to your TLS cert and key.
# Let's Encrypt default paths shown — adjust if you use a different CA.
CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
