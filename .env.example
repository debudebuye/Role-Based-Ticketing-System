# ── Root .env for docker-compose ─────────────────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose.
# This file is safe to commit — it contains no real secrets.

# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Node environment
NODE_ENV=production

# JWT — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

BCRYPT_ROUNDS=12

# CORS — comma-separated list of allowed origins (no trailing slash)
CORS_ORIGIN=https://yourdomain.com

# Email — leave EMAIL_USER/PASSWORD blank to use Ethereal test email
EMAIL_FROM=noreply@yourdomain.com
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=

# URLs
CLIENT_URL=https://yourdomain.com
VITE_API_URL=https://api.yourdomain.com/api/v1

LOG_LEVEL=info
