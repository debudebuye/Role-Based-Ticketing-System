NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/ticket-system

# Logging level: error | warn | info | debug (default: debug in dev, info in production)
LOG_LEVEL=debug

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRE=15m

# Must be different from JWT_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_REFRESH_EXPIRE=7d

BCRYPT_ROUNDS=12

# Comma-separated list of allowed origins (no trailing slash)
# e.g. http://localhost:5173,https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# Trust proxy (set to 1 when behind a load balancer / reverse proxy in production)
TRUST_PROXY=0

# Refresh token cookie
# In production the cookie is Secure + SameSite=Strict automatically (controlled by NODE_ENV).
# No extra env var needed — just ensure NODE_ENV=production in your deployment.

# Email Configuration
# Leave EMAIL_USER and EMAIL_PASSWORD blank to use Ethereal (test) email in development
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=
# REQUIRED: set to a real address you own (e.g. noreply@yourdomain.com)
# The server will not fall back to a default — leaving this blank will cause
# email delivery failures.
EMAIL_FROM=noreply@yourdomain.com

# Client URL (for email links)
CLIENT_URL=http://localhost:5173